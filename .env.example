# ERP 系统环境变量配置
# 复制此文件为 .env 并修改相应值

# PostgreSQL 数据库密码
POSTGRES_PASSWORD=请修改为强密码

# JWT 签名密钥（必须设置！请使用随机字符串，如：openssl rand -hex 32）
SECRET_KEY=

# CORS 允许的前端域名（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:8090

# 快递100 API 配置
KD100_KEY=
KD100_CUSTOMER=
KD100_CALLBACK_URL=

# 备份配置
BACKUP_KEEP_DAYS=30
BACKUP_HOUR=3

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 调试模式 (true/false)
DEBUG=false

# ERP 系统环境变量配置
# 复制此文件为 .env 并修改相应值

# === Required ===
POSTGRES_PASSWORD=change_me_to_strong_password
SECRET_KEY=run_openssl_rand_hex_32

# === Optional ===
DEBUG=false
CORS_ORIGINS=https://your-domain.com
BACKUP_ENCRYPTION_KEY=run_python_c_from_cryptography_fernet_import_Fernet_print_Fernet_generate_key_decode
API_KEYS_ENCRYPTION_SECRET=
AI_DB_PASSWORD=
DB_POOL_MIN=5
DB_POOL_MAX=50

# 快递100 API 配置
KD100_KEY=
KD100_CUSTOMER=
KD100_CALLBACK_URL=

# 备份配置
BACKUP_KEEP_DAYS=30
BACKUP_HOUR=3

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
